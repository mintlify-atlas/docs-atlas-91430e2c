  "keyFeatures": [
    "Live NYC DOB permit data from NYC Open Data (updated daily)",
    "Color-coded permit markers with recency fade visualization",
    "Interactive filtering by permit type, borough, and date range",
    "Coordinate projection system (lat/lng to isometric pixel conversion)",
    "Neighborhood labels with zoom-level LOD (5 boroughs → 40 major → 197 NTAs)",
    "Permit detail drawer with DOB BIS, ZoLa, and Google Maps integration",
    "Live helicopter overlay via ADS-B Exchange",
    "OpenSeadragon deep-zoom tile rendering with custom overlay system"
  ],
